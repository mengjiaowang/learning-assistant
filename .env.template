# ==========================================
# 学习助手 (Learning Assistant) - 环境变量配置模版
# 使用方法:
#   1. 复制此文件并重命名为 `.env` (注意点号开头)
#   2. 按照您的云端配置修改对应数值
# ==========================================

# [必填] GCP 项目 ID
PROJECT_ID=你的GCP项目ID

# [可选] 数据库配置
MISTAKE_MENTOR_FIRESTORE_DB=mistake-mentor-db
WORD_BUDDY_FIRESTORE_DB=word-buddy-db

# [可选] 后端 JWT 安全密钥 (生产环境建议更换为随机强密钥)
SECRET_KEY=yoursecretkeyhere

# [可选] 系统初始登录用户名和密码
ADMIN_USERNAME=admin
ADMIN_PASSWORD=你的初始密码

# [可选] 模型名称配置
ERASURE_MODEL=gemini-3.1-flash-image-preview
GEMINI_MODEL_NAME=gemini-3.1-pro-preview

# [可选] JWT 令牌过期时间位：分钟，默认 10080 (7天)
ACCESS_TOKEN_EXPIRE_MINUTES=10080
